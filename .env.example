# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- PostgreSQL ----
# Connection is configured in src/config/db.js. Tables/migrations are created
# in the Database Design phase (node-pg-migrate) — not yet used by the app.
DATABASE_URL=postgresql://username:password@localhost:5432/communityconnect

# ---- JWT ----
# Architecture: httpOnly cookie, 2-hour access token expiry (see docs/PROJECT_BLUEPRINT.md).
# Generate a strong value, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_before_auth_phase
JWT_EXPIRES_IN=2h

# ---- CSRF (Phase 10) ----
# Secret used to derive the double-submit CSRF cookie's HMAC.
# Generate a strong value the same way as JWT_SECRET above.
CSRF_SECRET=change_me_before_deploying

# ---- Logging ----
LOG_LEVEL=info
