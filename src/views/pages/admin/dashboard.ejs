<div class="page-header">
  <h1 id="greeting">Welcome, <%= user.name %></h1>
  <p>Platform overview for administrators.</p>
</div>

<section class="dashboard-section">
  <h2 class="section-title">Statistics</h2>
  <div class="stats-grid">
    <% stats.forEach(function (stat) { %>
    <%- include('../../partials/dashboard/statCard', { stat: stat }) %>
    <% }); %>
  </div>
</section>

<section class="dashboard-section">
  <h2 class="section-title">Quick Actions</h2>
  <div class="quick-actions">
    <% quickActions.forEach(function (action) { %> <% if (action.href) { %>
    <a href="<%= action.href %>" class="btn btn-secondary">
      <i class="<%= action.icon %>"></i>
      <%= action.label %>
    </a>
    <% } else { %>
    <button type="button" class="btn btn-secondary" disabled title="Coming soon">
      <i class="<%= action.icon %>"></i>
      <%= action.label %>
      <span class="badge badge-soft">Soon</span>
    </button>
    <% } %> <% }); %>
  </div>
</section>
