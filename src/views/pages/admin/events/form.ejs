<div class="page-header">
  <h1><%= mode==='create' ? 'Create Event' : 'Edit Event' %></h1>
  <p>
    <%= mode==='create' ? 'Fill in the details below to publish a new community event.' : 'Update the event details below.' %>
  </p>
</div>

<% if (errors && errors.length) { %>
<div class="alert alert-danger">
  <i class="fa-solid fa-circle-exclamation"></i>
  <ul>
    <% errors.forEach(function (message) { %>
    <li><%= message %></li>
    <% }); %>
  </ul>
</div>
<% } %>

<div class="card">
  <form method="POST" action="<%= formAction %>" enctype="multipart/form-data" novalidate>
    <div class="form-group">
      <label class="form-label" for="title">Event Title</label>
      <input
        class="form-control"
        type="text"
        id="title"
        name="title"
        value="<%= values.title || '' %>"
        required
        maxlength="200"
      />
    </div>

    <div class="form-group">
      <label class="form-label" for="categoryId">Category</label>
      <select class="form-control" id="categoryId" name="categoryId" required>
        <option value="">Select a category&hellip;</option>
        <% categories.forEach(function (cat) { %>
        <option value="<%= cat.id %>" <%= String(values.categoryId)===String(cat.id) ? 'selected' : '' %>>
          <%= cat.name %>
        </option>
        <% }); %>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label" for="description">Description</label>
      <textarea
        class="form-control"
        id="description"
        name="description"
        rows="5"
        required
      ><%= values.description || '' %></textarea>
    </div>

    <div class="form-group">
      <label class="form-label" for="location">Venue</label>
      <input
        class="form-control"
        type="text"
        id="location"
        name="location"
        value="<%= values.location || '' %>"
        required
        maxlength="255"
      />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="eventDate">Date</label>
        <input
          class="form-control"
          type="date"
          id="eventDate"
          name="eventDate"
          value="<%= values.eventDate || '' %>"
          required
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="startTime">Start Time</label>
        <input
          class="form-control"
          type="time"
          id="startTime"
          name="startTime"
          value="<%= values.startTime || '' %>"
          required
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="endTime">End Time</label>
        <input
          class="form-control"
          type="time"
          id="endTime"
          name="endTime"
          value="<%= values.endTime || '' %>"
          required
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="registrationDeadline">Registration Deadline</label>
        <input
          class="form-control"
          type="date"
          id="registrationDeadline"
          name="registrationDeadline"
          value="<%= values.registrationDeadline || '' %>"
          required
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="capacity">Maximum Volunteer Capacity</label>
        <input
          class="form-control"
          type="number"
          id="capacity"
          name="capacity"
          min="1"
          value="<%= values.capacity || '' %>"
          required
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="status">Event Status</label>
        <select class="form-control" id="status" name="status" required>
          <option value="draft" <%= values.status==='draft' || !values.status ? 'selected' : '' %>>Draft</option>
          <option value="published" <%= values.status==='published' ? 'selected' : '' %>>Published</option>
          <option value="closed" <%= values.status==='closed' ? 'selected' : '' %>>Closed</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="banner">Banner Image</label>
      <input
        class="form-control"
        type="file"
        id="banner"
        name="banner"
        accept="image/png,image/jpeg,image/webp"
      />
      <span class="form-hint">
        JPEG, PNG, or WEBP, up to 2MB.
        <% if (mode==='edit' ) { %>Leave empty to keep the current banner.<% } %>
      </span>
      <% if (currentBannerUrl) { %>
      <img src="<%= currentBannerUrl %>" alt="Current banner" class="banner-preview" />
      <% } %>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">
        <%= mode==='create' ? 'Create Event' : 'Save Changes' %>
      </button>
      <a href="<%= mode==='create' ? '/admin/events' : `/admin/events/${eventId}` %>" class="btn btn-ghost"
        >Cancel</a
      >
    </div>
  </form>
</div>
