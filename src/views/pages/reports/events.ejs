<%
  var qs = Object.entries(filters)
    .filter(function (e) { return e[1] !== undefined; })
    .map(function (e) { return encodeURIComponent(e[0]) + '=' + encodeURIComponent(e[1]); })
    .join('&');
%>
<div class="page-header">
  <div class="page-header-row">
    <div>
      <h1>Event Report</h1>
      <p>Registrations, attendance, and remaining capacity per event.</p>
    </div>
    <div class="page-header-actions">
      <a href="/admin/reports/events/export.csv<%= qs ? '?' + qs : '' %>" class="btn btn-secondary">
        <i class="fa-solid fa-file-csv"></i> Export CSV
      </a>
      <a href="/admin/reports/events/export.pdf<%= qs ? '?' + qs : '' %>" class="btn btn-secondary">
        <i class="fa-solid fa-file-pdf"></i> Export PDF
      </a>
    </div>
  </div>
</div>

<div class="card">
  <form method="GET" action="/admin/reports/events" class="filter-bar">
    <select class="form-control" name="eventId">
      <option value="">All Events</option>
      <% events.forEach(function (event) { %>
      <option value="<%= event.id %>" <%= String(filters.eventId)===String(event.id) ? 'selected' : '' %>>
        <%= event.title %>
      </option>
      <% }); %>
    </select>
    <input class="form-control" type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" placeholder="From" />
    <input class="form-control" type="date" name="dateTo" value="<%= filters.dateTo || '' %>" placeholder="To" />
    <button type="submit" class="btn btn-secondary"><i class="fa-solid fa-filter"></i> Filter</button>
    <a href="/admin/reports/events" class="btn btn-ghost">Reset</a>
  </form>
</div>

<section class="dashboard-section">
  <div class="card">
    <% if (rows.length===0) { %>
    <p class="hint">No events match your filters.</p>
    <% } else { %>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>Event</th>
            <th>Category</th>
            <th>Status</th>
            <th>Start</th>
            <th>Capacity</th>
            <th>Registrations</th>
            <th>Attendance</th>
            <th>Attendance Rate</th>
            <th>Remaining Capacity</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function (row) { %>
          <tr>
            <td><%= row.title %></td>
            <td><%= row.category_name %></td>
            <td><%= row.status %></td>
            <td><%= formatDate(row.start_datetime) %></td>
            <td><%= row.capacity %></td>
            <td><%= row.total_registrations %></td>
            <td><%= row.total_attendance %></td>
            <td><%= row.attendance_rate %>%</td>
            <td><%= row.remaining_capacity %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</section>
