{
  "root": true,
  "ignorePatterns": ["src/public/vendor/**"],
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "ignoreRestSiblings": true }],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["src/public/**/*.js"],
      "env": { "browser": true, "node": false }
    }
  ]
}
