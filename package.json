{
  "name": "communityconnect",
  "version": "0.1.0",
  "description": "Cloud-Based Integrated Platform for Enhancing Community Event, Volunteer and Donation Management",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "migrate:up": "node-pg-migrate up -m database/migrations",
    "migrate:down": "node-pg-migrate down -m database/migrations",
    "migrate:create": "node-pg-migrate create -m database/migrations",
    "migrate:redo": "node-pg-migrate redo -m database/migrations",
    "seed": "node database/seeders/001-initial-seed.js"
  },
  "keywords": [
    "community",
    "events",
    "volunteering",
    "donations",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  }
}
